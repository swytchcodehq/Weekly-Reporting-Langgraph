      "inputs": [
        {
          "body": {
            "LOCATION": "body",
            "REQUIRED": false,
            "TYPE": "OBJECT",
            "schema": {
              "properties": {
                "from": {
                  "required": true,
                  "type": "string"
                },
                "html": {
                  "required": false,
                  "type": "string"
                },
                "subject": {
                  "required": true,
                  "type": "string"
                },
                "text": {
                  "required": false,
                  "type": "string"
                },
                "to": {
                  "required": true,
                  "type": "any"
                }
              }
            }
          }
        }
      ],
      "integration": "resend.resend@v1.5.0",
      "method_hash": "",
      "output": {
        "schema": {
          "properties": {
            "id": {
              "required": false,
              "type": "string"
            }
          }
        },
        "status": 200
      },
      "summary": "Send an email",
      "type": "method"
    },
