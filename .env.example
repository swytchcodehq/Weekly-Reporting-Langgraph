# Google Sheets — https://console.cloud.google.com/apis/credentials
GOOGLE_ACCESS_TOKEN=your_google_oauth_bearer_token
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id   # from the sheet URL
GOOGLE_SHEETS_RANGE=Sheet1!A1:B10           # optional, this is the default

# Notion — https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=your_notion_database_id  # from the database URL

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Swytchcode — https://swytchcode.com (Settings, API keys)
SWYTCHCODE_TOKEN=your_swytchcode_token

REPORT_EMAIL=you@example.com
